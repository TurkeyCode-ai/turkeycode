# turkey-enterprise-v3 Environment Configuration
# Copy this to .env and fill in your values

# Required: Anthropic API key for Claude Code
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Jira integration
# JIRA_HOST=yourcompany.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_TOKEN=your-jira-api-token
# JIRA_PROJECT=PROJ

# Optional: GitHub authentication (required for private repos)
# GH_TOKEN enables: git push/pull to private repos, gh CLI, PR creation
# Create at: https://github.com/settings/tokens (needs 'repo' scope)
# GH_TOKEN=ghp_...

# GitHub owner (username or org) for auto-creating repos
# GITHUB_OWNER=your-username-or-org

# Optional: Git identity for commits
# GIT_AUTHOR_NAME=Turkey Enterprise
# GIT_AUTHOR_EMAIL=turkey@example.com
# GIT_COMMITTER_NAME=Turkey Enterprise
# GIT_COMMITTER_EMAIL=turkey@example.com
