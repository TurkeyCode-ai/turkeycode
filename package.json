{
  "name": "turkeycode",
  "version": "3.0.6",
  "description": "Open-source build engine — one prompt to a production-ready, QA-tested app. Any stack, any platform.",
  "main": "dist/index.js",
  "bin": {
    "turkeycode": "./dist/index.js",
    "turkey": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "build",
    "code-generation",
    "claude",
    "orchestrator",
    "fullstack",
    "deploy",
    "qa",
    "open-source"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TurkeyCode-ai/turkeycode.git"
  },
  "homepage": "https://turkeycode.ai",
  "bugs": {
    "url": "https://github.com/TurkeyCode-ai/turkeycode/issues"
  },
  "author": "TurkeyCode <hello@turkeycode.ai>",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "bcryptjs": "^3.0.3",
    "commander": "^12.0.0",
    "dotenv": "^17.2.4",
    "glob": "^10.3.10",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "uuid": "^13.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/glob": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.32",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^10.0.0",
    "ioredis-mock": "^8.9.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
